# Supabase (optional — local scores work without this)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Posthog
VITE_POSTHOG_KEY=
# Use your PostHog ingestion host, not the app UI host.
# US cloud example: https://us.i.posthog.com
# EU cloud example: https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Tip jar — Stripe Payment Link (supports Apple Pay, Google Pay, Card, BLIK)
# Create at: https://dashboard.stripe.com/payment-links → New link → "Let customer decide"
VITE_TIP_URL=
